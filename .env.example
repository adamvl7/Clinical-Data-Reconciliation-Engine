# Required: Google Gemini API key (get one at https://aistudio.google.com/apikey)
# Without this key the app runs in Demo Mode with realistic mock responses.
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Protects API endpoints with x-api-key header authentication.
# Leave unset to allow unauthenticated access (fine for local dev).
API_SECRET_KEY=
